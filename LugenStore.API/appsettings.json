{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=lugenstore;Username=lugenstore;Password=${DB_PASSWORD}"
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "LugenStore.API",
    "Audience": "LugenStore.Client",
    "ExpiresInHours": 2
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}